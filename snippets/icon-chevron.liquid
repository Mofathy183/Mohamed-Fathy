{% comment %}
  snippets/icon-chevron.liquid
  ------------------------------------------------------------------
  Reusable chevron-down icon used by the custom Size dropdown in the
  Gift Guide popup.

  The SVG uses `currentColor` so its stroke inherits the parent
  element's text color. Size is controlled entirely by CSS.
{% endcomment %}

<svg
  class="icon-chevron"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 15 9"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <path
    d="M1.06067 1.06067L7.06067 7.06067L13.0607 1.06067"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="square"
  />
</svg>