{% comment %}
  snippets/icon-close_x.liquid
  ------------------------------------------------------------------
  Reusable close ("X") icon for the Gift Guide product popup.

  The SVG uses `currentColor` so its stroke inherits the parent
  element's text color. Size is controlled entirely by CSS.
{% endcomment %}

<svg
  class="icon-close_x"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 17 17"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <path
    d="M4.24219 4.24279L12.7275 12.7281"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="square"
    stroke-linejoin="round"
  />
  <path
    d="M4.24219 12.7278L12.7275 4.24249"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="square"
    stroke-linejoin="round"
  />
</svg>